# ── Database ─────────────────────────────────────────────────
DB_URL=jdbc:mysql://localhost:3306/wedding_planner_db
DB_USER=root
DB_PASSWORD=root

# ── JWT ───────────────────────────────────────────────────────
# RS256 key pair lives in src/main/resources/META-INF/resources/
# privateKey.pem  — used for signing  (smallrye.jwt.sign.key.location)
# publicKey.pem   — used for verification (mp.jwt.verify.publickey.location)
# jaas-private.pem — used for JaaS video call tokens
# All .pem files are git-ignored and must be created locally.
JWT_ISSUER=https://voeux.ro

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JaaS (Jitsi as a Service) ────────────────────────────────
# Get these from https://jaas.8x8.vc -> your App -> API Keys
JAAS_APP_ID=vpaas-magic-cookie-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
JAAS_KID=vpaas-magic-cookie-xxxxxxxxxxxxxxxxxxxxxxxxxxxx/xxxxxx

# ── Daily.co (video rooms) ────────────────────────────────────
DAILY_CO_API_KEY=your-daily-co-api-key-here

# ── Resend (transactional email) ──────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_API_URL=https://api.resend.com

# ── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Supabase Storage ──────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── MySQL ─────────────────────────────────────────────────────
MYSQLHOST=localhost
MYSQLPORT=3306
MYSQLDATABASE=wedding_planner_db
MYSQLUSER=root
MYSQLPASSWORD=root
